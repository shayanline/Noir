[resource]
script = ExtResource("24_y36oc")
title = "INKFALL"
subtitle = "A HALLUCINATION OF SIN CITY"
blurb = "It always rains in Basin City. The whole town is black and white, except the things that bleed. Tap through the long, wet night."
picker_name = "STORY 0"
picker_tagline = "A HALLUCINATION"
music = "piano_noir"
music_vol = 0.62
acts = Array[ExtResource("1_2f1d4")]([SubResource("Resource_smyvv"), SubResource("Resource_od4v8"), SubResource("Resource_w64lb")])
