[sub_resource type="Resource" id="Resource_gi3fn"]
script = ExtResource("11_ksl6t")
text = "Up here the city's just a field of dirty stars."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_g727s"]
script = ExtResource("11_ksl6t")
text = "Crows watch. They've seen worse. So have I."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_5ack4"]
script = ExtResource("11_ksl6t")
text = "She stands on the ledge, between two kinds of falling."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_0wxeg"]
script = ExtResource("11_ksl6t")
text = "The rain'll wash it clean by morning. It always lies."
fx = PackedStringArray()

