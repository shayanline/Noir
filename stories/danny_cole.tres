[sub_resource type="Resource" id="Resource_1fvdh"]
script = ExtResource("12_afdgo")
text = "Word travels fast when a made man stops breathing."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_5qska"]
script = ExtResource("12_afdgo")
text = "They find him where the rain pools deepest. Three coats, three guns."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_gl42u"]
script = ExtResource("12_afdgo")
text = "He opens his mouth to deal one last time."
fx = PackedStringArray("muzzle")

[sub_resource type="Resource" id="Resource_bfgkj"]
script = ExtResource("12_afdgo")
text = "The guns answer first. The gutter drinks him down."
fx = PackedStringArray("muzzle", "blood", "lightning")

[sub_resource type="Resource" id="Resource_y1duh"]
script = ExtResource("12_afdgo")
text = "Basin City balances its books by morning. Danny Cole doesn't even leave a stain."
fx = PackedStringArray()

