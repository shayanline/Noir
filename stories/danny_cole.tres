[sub_resource type="Resource" id="Resource_ugdm7"]
script = ExtResource("12_afdgo")
text = "A collector trails him into the alley. Knuckles, bad teeth, worse intentions."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_e7ad1"]
script = ExtResource("12_afdgo")
text = "They go for the same gun. It only answers to one of them."
fx = PackedStringArray("muzzle", "blood", "lightning")

[sub_resource type="Resource" id="Resource_grh32"]
script = ExtResource("12_afdgo")
text = "The collector folds like a cheap hand. Danny didn't mean it. Doesn't matter."
fx = PackedStringArray()

[sub_resource type="Resource" id="Resource_7yt03"]
script = ExtResource("12_afdgo")
text = "He's not a gambler anymore. He's a <b>killer</b> with nowhere left to run."
fx = PackedStringArray()

